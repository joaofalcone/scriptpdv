while ($true) {
    $opcao = Selecionar-OpcaoPrincipal

    if (-not $opcao) {
        break
    }

    switch ($opcao) {
        "Borland" {
    Executar-ComJanela "Borland" {
        $zip = Join-Path $Pasta "Borland Shared.zip"
        $destino = "C:\Program Files (x86)\Common Files"

        if (-not (Test-Path $zip)) {
            throw "Arquivo não encontrado: $zip"
        }

        Unblock-File $zip -ErrorAction SilentlyContinue
        New-Item -ItemType Directory -Path $destino -Force | Out-Null
        Expand-Archive -Path $zip -DestinationPath $destino -Force

        if (-not (Test-Path "C:\Program Files (x86)\Common Files\Borland Shared")) {
            throw "Falha ao extrair Borland Shared."
        }
    }
}

        "PDV" {
    try {
        $arquivo = Join-Path $Pasta "kiodai_instpdv_160517_auto.exe"

        Unblock-File $arquivo -ErrorAction SilentlyContinue
        Start-Process -FilePath $arquivo -Wait | Out-Null

        Start-Sleep -Seconds 3
        Get-Process CONFIG, Checkout -ErrorAction SilentlyContinue | Stop-Process -Force

        Mostrar-Mensagem "PDV instalado com sucesso."
    }
    catch {
        Mostrar-Erro $_.Exception.Message
    }
}

        "PinPad" {
            $modelo = Selecionar-PinPad

            if (-not $modelo) {
                continue
            }

            switch ($modelo) {
                "Gertec" {
                    Instalar-Processo "Driver Gertec" (Join-Path $Pasta "gertec.exe") "/S"
                }

                "Ingenico" {
                    Instalar-Processo "Driver Ingenico" (Join-Path $Pasta "ingenico.exe") "/S"
                }

                "Verifone" {
                    if ([Environment]::Is64BitOperatingSystem) {
                        $arquivo = Join-Path $Pasta "verifone64.msi"
                    }
                    else {
                        $arquivo = Join-Path $Pasta "verifone32.msi"
                    }

                    Instalar-Processo "Driver Verifone" "msiexec.exe" "/i `"$arquivo`" /qn /norestart"
                }
            }
        }
    }
}
