function Executar-ComJanela {
    param(
        [string]$Titulo,
        [scriptblock]$Acao
    )

    $form = New-Object System.Windows.Forms.Form
    $form.Text = $Titulo
    $form.Size = New-Object System.Drawing.Size(360,130)
    $form.StartPosition = "CenterScreen"
    $form.FormBorderStyle = "FixedDialog"
    $form.MaximizeBox = $false
    $form.MinimizeBox = $false

    $label = New-Object System.Windows.Forms.Label
    $label.Text = "Processando, aguarde..."
    $label.AutoSize = $true
    $label.Location = New-Object System.Drawing.Point(20,20)
    $form.Controls.Add($label)

    $progress = New-Object System.Windows.Forms.ProgressBar
    $progress.Location = New-Object System.Drawing.Point(20,50)
    $progress.Size = New-Object System.Drawing.Size(300,22)
    $progress.Style = "Marquee"
    $progress.MarqueeAnimationSpeed = 30
    $form.Controls.Add($progress)

    $timer = New-Object System.Windows.Forms.Timer
    $timer.Interval = 300
    $timer.Add_Tick({
        $timer.Stop()

        try {
            & $Acao
            $progress.Style = "Blocks"
            $progress.Value = 100
            $label.Text = "Concluído com sucesso."
            Start-Sleep -Seconds 1
            $form.Close()
        }
        catch {
            $progress.Style = "Blocks"
            $progress.Value = 100
            $label.Text = "Falha na operação."
            [System.Windows.Forms.MessageBox]::Show(
                $_.Exception.Message,
                "Erro",
                [System.Windows.Forms.MessageBoxButtons]::OK,
                [System.Windows.Forms.MessageBoxIcon]::Error
            ) | Out-Null
            $form.Close()
        }
    })

    $form.Add_Shown({ $timer.Start() })
    $form.ShowDialog() | Out-Null
}

function Instalar-Processo {
    param (
        [string]$Nome,
        [string]$Executavel,
        [string]$Argumentos
    )

    Executar-ComJanela $Nome {
        if (-not (Test-Path $Executavel) -and $Executavel -ne "msiexec.exe") {
            throw "Arquivo não encontrado: $Executavel"
        }

        if ($Executavel -ne "msiexec.exe") {
            Unblock-File $Executavel -ErrorAction SilentlyContinue
        }

        $processo = Start-Process `
            -FilePath $Executavel `
            -ArgumentList $Argumentos `
            -Wait `
            -PassThru

        if (-not $processo -or $processo.ExitCode -ne 0) {
            throw "$Nome terminou com código: $($processo.ExitCode)"
        }
    }
}

